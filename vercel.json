{
  "version": 2,
  "builds": [
    { "src": "api/generate.js", "use": "@vercel/node" },
    { "src": "api/analyze.js",  "use": "@vercel/node" },
    { "src": "public/**",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/analyze",  "dest": "/api/analyze.js"  },
    { "src": "/(.*)",         "dest": "/public/$1"       }
  ]
}
